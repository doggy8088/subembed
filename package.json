{
  "name": "subembed",
  "version": "0.1.5",
  "description": "Thin npm wrapper for the subembed Rust CLI",
  "bin": {
    "subembed": "npm/cli.cjs"
  },
  "scripts": {
    "postinstall": "node npm/postinstall.cjs",
    "test": "node --test tests/postinstall.test.cjs",
    "prepublishOnly": "npm test && npm pack --dry-run && node npm/prepublish-check.cjs"
  },
  "files": [
    "npm/cli.cjs",
    "npm/postinstall.cjs",
    "npm/prepublish-check.cjs",
    "npm/shared.cjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doggy8088/subembed.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rust",
    "cli",
    "subtitle",
    "video",
    "ffmpeg"
  ],
  "author": "Will 保哥",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
